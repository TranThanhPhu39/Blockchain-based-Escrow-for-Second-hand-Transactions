# ============================================================
# .env.example — Template cho environment variables
# SAO CHÉP file này thành .env và điền giá trị thực
# KHÔNG bao giờ commit file .env lên Git
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Lấy từ MongoDB Atlas: Database → Connect → Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/escrow_db?retryWrites=true&w=majority

# JWT
# Tạo secret ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d

# Frontend URL (cho CORS)
CLIENT_URL=http://localhost:3000

# Auto release escrow sau X ngày nếu buyer không confirm
AUTO_RELEASE_DAYS=7

# Blockchain (Backend 3 sẽ dùng)
# Lấy từ Alchemy: https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key
BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_api_key

# Private key của admin wallet (dùng để gọi smart contract)
# CẢNH BÁO: Không bao giờ commit key này lên Git!
ADMIN_PRIVATE_KEY=your_admin_wallet_private_key

# Smart contract address (sau khi deploy)
CONTRACT_ADDRESS=0x...

# Cloudinary (Backend 2 sẽ dùng)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
