# ============================================================
# .env.example — Template cho environment variables
# COPY file này thành .env và điền giá trị thực
# KHÔNG bao giờ commit file .env lên Git
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/escrow_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d

# Frontend URL (cho CORS)
CLIENT_URL=http://localhost:3000

# Auto release escrow sau X ngày nếu buyer không confirm
AUTO_RELEASE_DAYS=7

# ── BLOCKCHAIN ──────────────────────────────────────────────
# Lấy từ Alchemy: https://dashboard.alchemy.com
# Tạo App → Chọn Polygon Amoy → Copy HTTPS URL
BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_api_key

# Private key của admin wallet dùng để gọi contract (releaseFunds, refundBuyer)
# Lấy từ MetaMask: Account Details → Export Private Key
# CẢNH BÁO: KHÔNG BAO GIỜ commit key này!
ADMIN_PRIVATE_KEY=your_admin_wallet_private_key_without_0x_prefix

# Địa chỉ smart contract sau khi deploy lên Polygon Amoy
# Smart Contract team sẽ cung cấp sau khi deploy
CONTRACT_ADDRESS=0x_your_deployed_contract_address

# Cloudinary (Backend 2 sẽ dùng)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
