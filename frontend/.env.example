# ============================================================
# .env.example — Template cho frontend environment variables
# SAO CHÉP file này thành .env và điền giá trị thực
# KHÔNG bao giờ commit file .env lên Git
#
# Vite CHỈ expose các biến có tiền tố VITE_ ra phía client code
# (import.meta.env.VITE_XXX) — đây là quy định bắt buộc của Vite,
# không phải lựa chọn của project. Biến không có tiền tố VITE_ sẽ
# KHÔNG truy cập được trong src/lib/web3.js, src/lib/api.js, v.v.
# ============================================================

# URL của backend Express API (xem backend/.env PORT)
VITE_API_URL=http://localhost:5000

# Địa chỉ smart contract Escrow đã deploy — LẤY TỪ
# smart-contract/deployments/amoy.json (trường escrowContract)
VITE_CONTRACT_ADDRESS=0x8352BC4b52895278bC89431E4f47f22511BC750f

# Địa chỉ token MockUSDC — LẤY TỪ smart-contract/deployments/amoy.json
# (trường paymentToken / mockUSDC, hiện 2 trường này trùng giá trị)
VITE_USDC_ADDRESS=0xd802C175b40E07dB11E472E9aDA3Aeb3bd7dBCf4

# Chain ID của Polygon Amoy Testnet dạng hex (80002 decimal = 0x13882 hex)
# Dùng để kiểm tra/yêu cầu MetaMask chuyển đúng network trước khi
# thực hiện giao dịch — xem ensureCorrectNetwork() trong lib/web3.js
VITE_CHAIN_ID_HEX=0x13882
